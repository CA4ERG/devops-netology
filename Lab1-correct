#include <stdio.h>   // Для printf
#include <math.h>    // Для sqrt и pow

int main() {
    // Объявляем вещественные переменные
    double a, b, c;
    
    // Присваиваем им значения (можно менять)
    a = 1.0;
    b = -3.0;
    c = 2.0;

    // Вычисляем дискриминант
    double D = pow(b, 2) - 4 * a * c;

    // Проверяем значение дискриминанта
    if (D > 0) {
        // Два различных корня
        double x1 = (-b + sqrt(D)) / (2 * a);
        double x2 = (-b - sqrt(D)) / (2 * a);
        printf("Два различных корня: x1 = %lf, x2 = %lf\n", x1, x2);
    } else if (D == 0) {
        // Один корень
        double x = -b / (2 * a);
        printf("Один корень: x = %lf\n", x);
    } else {
        // D < 0, корней в действительных числах нет
        printf("Действительных корней нет.\n");
    }

    return 0;
}
