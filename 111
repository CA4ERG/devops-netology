    out = fopen("result.txt", "w");
    
    if(!in || !out) {
        printf("Error opening files\n");
        return 1;
    }
    
    printf("=== People born after 1980 ===\n");
    while(fgets(buf, MAX_LINE, in)) {
        // Extract year from end of line
        year = atoi(buf + strlen(buf) - 5);
        
        if(year > 1980) {
            fputs(buf, out);
            printf("%s", buf);
        }
    }
    
    // Find all Ivanovs
    rewind(in);
    count = 0;
    printf("\n=== All Ivanovs ===\n");
