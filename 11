#include <stdio.h>
#include <string.h>
#include <ctype.h>

int main(){FILE *in=fopen("people.txt","r"),*out=fopen("result.txt","w");
char buf[256],*p,*e;int y;
if(!in||!out)return 1;
while(fgets(buf,256,in)){
p=buf+strlen(buf)-1;
while(p>buf&&!isdigit(*p))p--;
e=p;
while(p>buf&&isdigit(*p))p--;
p++;y=0;
while(p<=e)y=y*10+*p++-'0';
if(y>1980)fputs(buf,out);
}
fclose(in);fclose(out);
return 0;
}
